{
  "name": "@ancplua/typespec-emit-csharp",
  "version": "0.1.0",
  "description": "ANcpLua TypeSpec emitter for C# records/enums with @csharpNamespace routing",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
