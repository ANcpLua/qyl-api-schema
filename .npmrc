# INSTALL-time scope map: resolve @ancplua/* build dependencies (e.g. @ancplua/typespec-otel-semconv)
# from GitHub Packages for npm install AND Renovate. CI auth comes from setup-node
# (NODE_AUTH_TOKEN=GITHUB_TOKEN); local dev needs a GitHub PAT (read:packages) in ~/.npmrc.
# NOTE: this repo's OWN package (@ancplua/qyl-api-schema) PUBLISHES to npmjs.org, not GitHub Packages
# — publish.yml forces that past this scope map with --@ancplua:registry=https://registry.npmjs.org.
@ancplua:registry=https://npm.pkg.github.com
