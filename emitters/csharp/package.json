{
  "name": "@ancplua/typespec-emit-csharp",
  "version": "0.1.0",
  "description": "ANcpLua TypeSpec emitter for C# DTOs, enums, and explicit polymorphic unions",
  "type": "module",
  "main": "dist/index.js",
  "tspMain": "lib/main.tsp",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p ."
  },
  "peerDependencies": {
    "@typespec/compiler": "^1.13.0-dev",
    "@typespec/http": "^1.13.0"
  },
  "devDependencies": {
    "@types/node": "25.9.5",
    "@typespec/compiler": "1.13.0",
    "@typespec/http": "1.13.0",
    "typescript": "6.0.3"
  }
}
